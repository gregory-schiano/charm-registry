CHARM_REGISTRY_LISTEN=:8080
CHARM_REGISTRY_PUBLIC_API_URL=http://localhost:8080
CHARM_REGISTRY_PUBLIC_STORAGE_URL=http://localhost:8080
CHARM_REGISTRY_PUBLIC_REGISTRY_URL=https://localhost:5000

CHARM_REGISTRY_DATABASE_URL=postgres://postgres:postgres@localhost:5432/charm_registry?sslmode=disable

CHARM_REGISTRY_S3_BUCKET=charm-registry
CHARM_REGISTRY_S3_REGION=us-east-1
CHARM_REGISTRY_S3_ENDPOINT=http://localhost:9000
CHARM_REGISTRY_S3_ACCESS_KEY_ID=minioadmin
CHARM_REGISTRY_S3_SECRET_ACCESS_KEY=minioadmin
CHARM_REGISTRY_S3_USE_PATH_STYLE=true

CHARM_REGISTRY_OIDC_ISSUER_URL=
CHARM_REGISTRY_OIDC_CLIENT_ID=
CHARM_REGISTRY_OIDC_USERNAME_CLAIM=preferred_username
CHARM_REGISTRY_OIDC_DISPLAY_NAME_CLAIM=name
CHARM_REGISTRY_OIDC_EMAIL_CLAIM=email

CHARM_REGISTRY_ENABLE_INSECURE_DEV_AUTH=true

CHARM_REGISTRY_REGISTRY_USERNAME=registry
CHARM_REGISTRY_REGISTRY_PASSWORD=registry-secret
CHARM_REGISTRY_REGISTRY_REPOSITORY_ROOT=charms

CHARM_REGISTRY_SERVER_READ_HEADER_TIMEOUT=10s
CHARM_REGISTRY_SERVER_READ_TIMEOUT=30s
CHARM_REGISTRY_SERVER_WRITE_TIMEOUT=30s
CHARM_REGISTRY_SERVER_IDLE_TIMEOUT=2m
CHARM_REGISTRY_SERVER_SHUTDOWN_TIMEOUT=30s
CHARM_REGISTRY_SERVER_MAX_HEADER_BYTES=1048576
CHARM_REGISTRY_MAX_JSON_BODY_BYTES=1048576
CHARM_REGISTRY_MAX_UPLOAD_BYTES=67108864
