CHARM_REGISTRY_LISTEN=:8080
CHARM_REGISTRY_PUBLIC_API_URL=http://localhost:8080
CHARM_REGISTRY_PUBLIC_STORAGE_URL=http://localhost:8080
# For Juju or any external client running outside the Docker host, set these to a
# reachable host/IP instead of localhost, for example:
# CHARM_REGISTRY_PUBLIC_API_URL=http://192.0.2.10:8080
# CHARM_REGISTRY_PUBLIC_STORAGE_URL=http://192.0.2.10:8080
# The Harbor TLS cert SANs are derived from CHARM_REGISTRY_PUBLIC_REGISTRY_URL
# and CHARM_REGISTRY_HARBOR_URL when `make up`/`make harbor-prepare` runs.
CHARM_REGISTRY_PUBLIC_REGISTRY_URL=https://localhost:9443

CHARM_REGISTRY_DATABASE_URL=postgres://postgres:postgres@localhost:5432/charm_registry?sslmode=disable

CHARM_REGISTRY_S3_BUCKET=charm-registry-blobs
CHARM_REGISTRY_S3_REGION=us-east-1
CHARM_REGISTRY_S3_ENDPOINT=http://localhost:9000
CHARM_REGISTRY_S3_ACCESS_KEY_ID=registry-app
CHARM_REGISTRY_S3_SECRET_ACCESS_KEY=registry-app-secret
CHARM_REGISTRY_S3_USE_PATH_STYLE=true

HARBOR_S3_BUCKET=harbor-registry
HARBOR_S3_REGION=us-east-1
HARBOR_S3_REGION_ENDPOINT=http://minio:9000
HARBOR_S3_ACCESS_KEY_ID=harbor-registry
HARBOR_S3_SECRET_ACCESS_KEY=harbor-registry-secret
HARBOR_S3_SECURE=false
HARBOR_DATABASE_PASSWORD=root123

CHARM_REGISTRY_OIDC_ISSUER_URL=
CHARM_REGISTRY_OIDC_CLIENT_ID=
CHARM_REGISTRY_OIDC_USERNAME_CLAIM=preferred_username
CHARM_REGISTRY_OIDC_DISPLAY_NAME_CLAIM=name
CHARM_REGISTRY_OIDC_EMAIL_CLAIM=email
CHARM_REGISTRY_ADMIN_SUBJECTS=
CHARM_REGISTRY_ADMIN_EMAILS=
CHARM_REGISTRY_ADMIN_USERNAMES=

CHARM_REGISTRY_ENABLE_INSECURE_DEV_AUTH=true

CHARM_REGISTRY_HARBOR_URL=https://localhost:9443
CHARM_REGISTRY_HARBOR_API_URL=https://harbor-proxy:8443/api/v2.0
CHARM_REGISTRY_HARBOR_ADMIN_USERNAME=admin
CHARM_REGISTRY_HARBOR_ADMIN_PASSWORD=Harbor12345
CHARM_REGISTRY_HARBOR_PROJECT_PREFIX=charm
CHARM_REGISTRY_HARBOR_PULL_ROBOT_PREFIX=pull
CHARM_REGISTRY_HARBOR_PUSH_ROBOT_PREFIX=push
CHARM_REGISTRY_HARBOR_SECRET_KEY=replace-this-secret
CHARM_REGISTRY_HARBOR_INSECURE_SKIP_VERIFY=true
HARBOR_HTTP_PORT=9081
HARBOR_HTTPS_PORT=9443

CHARM_REGISTRY_SERVER_READ_HEADER_TIMEOUT=10s
CHARM_REGISTRY_SERVER_READ_TIMEOUT=30s
CHARM_REGISTRY_SERVER_WRITE_TIMEOUT=30s
CHARM_REGISTRY_SERVER_IDLE_TIMEOUT=2m
CHARM_REGISTRY_SERVER_SHUTDOWN_TIMEOUT=30s
CHARM_REGISTRY_SERVER_MAX_HEADER_BYTES=1048576
CHARM_REGISTRY_MAX_JSON_BODY_BYTES=1048576
CHARM_REGISTRY_MAX_UPLOAD_BYTES=67108864
